#include <Wire.h>

// ----- BTS7960 핀 설정 -----
#define RPWM 6
#define LPWM 5
#define PRESSURE_PIN A0

// ----- 설정값 -----
const int motorSpeed = 150;                
const int pressureThreshold = 300;         // 상자에 닿았다고 판단할 압력 센서 기준값
const unsigned long forwardTime = 20000;   // 최대 전진 허용 시간 (안전 장치)
const unsigned long initTime = 10000;      // 끝까지 후진(원위치)하는 데 걸리는 시간 (10초)

// 통신 및 제어 상태 변수 (처음 켜졌을 때는 대기 상태 'W'로 시작)
volatile char status = 'W'; 

void setup() {
  pinMode(RPWM, OUTPUT);
  pinMode(LPWM, OUTPUT);
  pinMode(PRESSURE_PIN, INPUT);

  Serial.begin(115200);
  
  Wire.begin(9); // 슬레이브 주소 9
  Wire.onReceive(receiveEvent);
  Wire.onRequest(requestEvent);

  stopMotor();
  Serial.println(">>> Linear Actuator Slave (9) Ready.");
}

void loop() {
  // ----------------------------------------------------
  // 1. 마스터로부터 'G'를 받았을 때: 상자 밀기 (전진)
  // ----------------------------------------------------
  if (status == 'G') {
    Serial.println(">>> [전진 시작] 상자를 향해 이동...");
    status = 'R'; // 동작 중(Running) 상태로 변경

    // 압력 센서가 pressureThreshold(300)에 도달할 때까지 전진
    moveWithPressureCheck(1, motorSpeed, forwardTime);

    // 상자에 닿아서 멈췄으므로 상태를 완료(D)로 변경하여 마스터에게 보고
    status = 'D'; 
    Serial.println(">>> [전진 완료] 상자 압착 완료. (Status: D)");
  }
  
  // ----------------------------------------------------
  // 2. 마스터로부터 'I'를 받았을 때: 초기화 및 복귀 (후진)
  // ----------------------------------------------------
  else if (status == 'I') {
    Serial.println(">>> [초기화/후진 시작] 리니어 원위치 복귀...");
    status = 'R'; // 동작 중(Running) 상태로 변경

    // 10초(initTime) 동안 끝까지 후진
    moveTimeCheck(-1, motorSpeed, initTime);

    // 💡 [핵심 수정] 후진 완료 후 'D'(Done)로 변경하여 마스터의 무한 대기를 풀어줌
    status = 'D'; 
    Serial.println(">>> [원위치 완료] 초기화 성공. (Status: D)\n");
  }
}

// ----- I2C 통신 함수 -----

void receiveEvent(int howMany) {
  if (Wire.available()) {
    char c = Wire.read();
    
    if (c == 'G') {
      status = 'G'; // 전진(작동) 명령
    } 
    else if (c == 'I') {
      status = 'I'; // 초기화(Homing) 명령 수신
    }
  }
}

void requestEvent() {
  Wire.write(status); // 마스터가 물어보면 현재 상태 대답
}

// ----- 모터 제어 기본 함수 -----

void stopMotor() {
  analogWrite(RPWM, 0);
  analogWrite(LPWM, 0);
}

void forwardMotor(int s) {
  analogWrite(LPWM, 0);
  analogWrite(RPWM, s);
}

void backwardMotor(int s) {
  analogWrite(RPWM, 0); 
  analogWrite(LPWM, s);
}

// ----- 모터 구동 응용 함수 -----

// 1. 시간 기반 후진 함수 (Z축 이동 및 초기화 시 사용)
void moveTimeCheck(int direction, int speedVal, unsigned long duration) {
  unsigned long startTime = millis();
  
  if (direction == 1) forwardMotor(speedVal);
  else if (direction == -1) backwardMotor(speedVal);

  // 이 내부 인터럽트 구조 덕분에 후진하는 동안에도 마스터와의 I2C 통신을 정상 처리합니다.
  while (millis() - startTime < duration) {
    delay(10); 
  }
  stopMotor();
}

// 2. 압력 센서 체크 전진 함수 (상자 밀 때 사용)
void moveWithPressureCheck(int direction, int speedVal, unsigned long duration) {
  unsigned long startTime = millis();
  unsigned long ignoreTime = 1000; // 초기 1초 노이즈 무시

  if (direction == 1) forwardMotor(speedVal);
  else if (direction == -1) backwardMotor(speedVal);

  while (millis() - startTime < duration) {
    int pressureValue = analogRead(PRESSURE_PIN);

    // 1초 이후부터 압력 체크
    if (millis() - startTime > ignoreTime) {
      if (pressureValue >= pressureThreshold) {
        Serial.print("!!! 압력 감지 멈춤 !!! 수치: ");
        Serial.println(pressureValue);
        break; 
      }
    }
    delay(20);
  }
  stopMotor();
}
